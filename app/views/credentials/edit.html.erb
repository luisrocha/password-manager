<% content_for :title, "Edit Credential" %>

<main class="credentials-page">
  <header>
    <h1>Edit Credential</h1>
    <p>Update the selected credential details.</p>
    <%= link_to "Back to list", credentials_path %>
  </header>

  <% if notice.present? %>
    <p class="flash notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="flash alert"><%= alert %></p>
  <% end %>

  <section class="panel">
    <%= form_with model: @credential, url: credential_path(@credential), method: :patch, local: true do |f| %>
      <div class="grid">
        <%= f.label :name %>
        <%= f.text_field :name, required: true %>

        <%= f.label :domain %>
        <%= f.text_field :domain %>

        <%= f.label :category %>
        <%= f.select :category, Credential::CATEGORIES %>

        <%= f.label :username %>
        <%= f.text_field :username %>

        <%= f.label :password %>
        <%= f.password_field :password %>

        <%= f.label :notes %>
        <%= f.text_area :notes, rows: 3 %>
      </div>

      <%= f.submit "Update" %>
    <% end %>
  </section>
</main>
