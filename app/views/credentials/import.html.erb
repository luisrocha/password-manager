<% content_for :title, "Import CSV" %>

<main class="credentials-page">
  <header>
    <h1>Import 1Password CSV</h1>
    <p>Upload an exported 1Password CSV file to add items to the vault.</p>
    <%= link_to "Back to list", credentials_path %>
  </header>

  <% if notice.present? %>
    <p class="flash notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="flash alert"><%= alert %></p>
  <% end %>

  <section class="panel">
    <%= form_with url: import_credentials_path, method: :post, multipart: true, local: true do |f| %>
      <div class="grid">
        <%= f.label :file, "CSV file" %>
        <%= f.file_field :file, accept: ".csv,text/csv", required: true %>
      </div>

      <%= f.submit "Import" %>
    <% end %>
  </section>
</main>
