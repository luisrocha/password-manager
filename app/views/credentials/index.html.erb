<% content_for :title, "Password Manager" %>

<main class="credentials-page">
  <header>
    <h1>Password Manager</h1>
    <p>Search credentials by name or domain and reveal secret fields only when needed.</p>
    <nav class="page-actions" aria-label="Credential actions">
      <%= link_to "Add Item", new_credential_path, class: "button-link" %>
      <%= link_to "Import CSV", import_credentials_path, class: "button-link secondary-button-link" %>
      <%= button_to "Lock Vault", lock_path, method: :delete, form: { class: "inline-form" } %>
    </nav>
  </header>

  <% if notice.present? %>
    <p class="flash notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="flash alert"><%= alert %></p>
  <% end %>

  <section class="panel">
    <h2>Search</h2>
    <%= form_with url: credentials_path, method: :get, local: true do |f| %>
      <%= f.search_field :q, value: @query, placeholder: "Search by name or domain" %>
      <%= f.submit "Search" %>
      <%= link_to "Clear", credentials_path %>
    <% end %>
  </section>

  <section class="panel">
    <h2>Stored Items (<%= @credentials.count %>)</h2>
    <% if @credentials.empty? %>
      <p class="empty-state">No stored items yet.</p>
    <% else %>
      <div class="table-wrap">
        <table class="stored-items-table">
          <thead>
            <tr>
              <th>Item</th>
              <th>Category</th>
              <th>Username</th>
              <th>Password</th>
              <th>Notes</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @credentials.each do |credential| %>
              <tr>
                <td>
                  <div class="item-main"><%= credential.name %></div>
                  <div class="item-sub"><%= credential.domain.presence || "No domain" %></div>
                </td>
                <td>
                  <span class="category-pill"><%= credential.category %></span>
                </td>
                <td>
                  <details>
                    <summary>Reveal</summary>
                    <code><%= credential.username.presence || "(empty)" %></code>
                  </details>
                </td>
                <td>
                  <details>
                    <summary>Reveal</summary>
                    <code><%= credential.password.presence || "(empty)" %></code>
                  </details>
                </td>
                <td>
                  <details>
                    <summary>Reveal</summary>
                    <code><%= credential.notes.presence || "(empty)" %></code>
                  </details>
                </td>
                <td class="actions">
                  <%= link_to "Edit", edit_credential_path(credential), class: "action-link" %>
                  <%= button_to "Delete", credential_path(credential), method: :delete, form: { class: "inline-form" }, data: { turbo_confirm: "Delete this credential?" }, class: "action-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>
</main>
