#!/usr/bin/env bash
set -euo pipefail

blocked_pattern='(^|/)\.env($|\.)|^config/master\.key$|^\.kamal/secrets$|\.pem$|\.key$'

tracked_blocked="$(git ls-files | rg -n "$blocked_pattern" || true)"
if [ -n "$tracked_blocked" ]; then
  echo "Blocked secret files are tracked by git:" >&2
  echo "$tracked_blocked" >&2
  exit 1
fi

echo "Security check passed: no blocked secret files are tracked."
